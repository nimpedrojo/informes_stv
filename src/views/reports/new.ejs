<h1 class="mb-4">Nuevo informe</h1>

<form method="POST" action="/reports/new">
  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Nombre <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_name"
        class="form-control <%= validationErrors.player_name ? 'is-invalid' : '' %>"
        value="<%= formData.player_name || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_name) { %>
      <div class="invalid-feedback">El nombre es obligatorio.</div>
      <% } %>
    </div>
    <div class="col-md-4">
      <label class="form-label">Apellidos <span class="text-danger">*</span></label>
      <input
        type="text"
        name="player_surname"
        class="form-control <%= validationErrors.player_surname ? 'is-invalid' : '' %>"
        value="<%= formData.player_surname || '' %>"
        required
        aria-required="true"
      />
      <% if (validationErrors.player_surname) { %>
      <div class="invalid-feedback">Los apellidos son obligatorios.</div>
      <% } %>
    </div>
    <div class="col-md-2">
      <label class="form-label">Año</label>
      <input type="number" name="year" class="form-control" />
    </div>
    <div class="col-md-2">
      <label class="form-label">Lateralidad</label>
      <input type="text" name="laterality" class="form-control" />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <label class="form-label">Club</label>
      <input type="text" name="club" class="form-control" />
    </div>
    <div class="col-md-4">
      <label class="form-label">Equipo</label>
      <input type="text" name="team" class="form-control" />
    </div>
    <div class="col-md-4">
      <label class="form-label">Contacto</label>
      <input type="text" name="contact" class="form-control" />
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Posición 1</label>
      <input type="text" name="pos1" class="form-control" />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 2</label>
      <input type="text" name="pos2" class="form-control" />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 3</label>
      <input type="text" name="pos3" class="form-control" />
    </div>
    <div class="col-md-3">
      <label class="form-label">Posición 4</label>
      <input type="text" name="pos4" class="form-control" />
    </div>
  </div>

  <div class="row">
    <div class="col-md-6">
      <div class="card mb-3">
        <div class="card-header fw-bold">Valoración técnica</div>
        <div class="card-body">
          <div class="row mb-2">
            <div class="col-8">Cobertura de balón</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_cobertura_balon"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Conducción</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_conduccion"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Control</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_control"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Regate</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_regate"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Disparo</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_disparo"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Pase</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_pase"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Remate de cabeza</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_remate_cabeza"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Anticipación</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tech_anticipacion"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-8 fw-bold">Total técnico</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                readonly
                name="tech_total"
                class="form-control form-control-sm"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header fw-bold">Valoración física</div>
        <div class="card-body">
          <div class="row mb-2">
            <div class="col-8">Capacidad de sacrificio</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_sacrificio"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Velocidad punta</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_velocidad_punta"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Velocidad de reacción</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_velocidad_reaccion"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Fuerza</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_fuerza"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Potencia</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_potencia"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Resistencia</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_resistencia"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Coordinación</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="phys_coordinacion"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-8 fw-bold">Total físico</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                readonly
                name="phys_total"
                class="form-control form-control-sm"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card mb-3">
        <div class="card-header fw-bold">Valoración táctica</div>
        <div class="card-body">
          <div class="row mb-2">
            <div class="col-8">Transición ataque-defensa</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_transicion_ataque_defensa"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Movimientos sin balón</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_movimientos_sin_balon"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Ayudas defensivas</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_ayudas_defensivas"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Ayudas ofensivas</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_ayudas_ofensivas"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Desmarques</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_desmarques"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Marcajes</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="tact_marcajes"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-8 fw-bold">Total táctico</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                readonly
                name="tact_total"
                class="form-control form-control-sm"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header fw-bold">Valoración psicológica</div>
        <div class="card-body">
          <div class="row mb-2">
            <div class="col-8">Concentración</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="psych_concentracion"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Control emocional</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="psych_control_emocional"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Reacción errores arbitrales</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="psych_reaccion_errores_arbitrales"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-8 fw-bold">Total psicológico</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                readonly
                name="psych_total"
                class="form-control form-control-sm"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-header fw-bold">Personalidad</div>
        <div class="card-body">
          <div class="row mb-2">
            <div class="col-8">Liderazgo</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="pers_liderazgo"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Disciplina</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="pers_disciplina"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Reacción a correcciones del compañero</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="pers_reaccion_correcciones_companero"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-8">Reacción a correcciones de los técnicos</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                name="pers_reaccion_correcciones_tecnico"
                class="form-control form-control-sm"
              />
            </div>
          </div>
          <div class="row mt-2">
            <div class="col-8 fw-bold">Total personalidad</div>
            <div class="col-4">
              <input
                type="number"
                step="0.01"
                readonly
                name="pers_total"
                class="form-control form-control-sm"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <label class="form-label">Valoración global</label>
      <input
        type="number"
        step="0.01"
        name="overall_rating"
        class="form-control"
      />
    </div>
    <div class="col-md-3">
      <label class="form-label">Recomendación</label>
      <input type="text" name="recommendation" class="form-control" />
    </div>
    <div class="col-md-3">
      <label class="form-label">Fiabilidad info</label>
      <input
        type="number"
        step="0.01"
        name="info_reliability"
        class="form-control"
      />
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label">Comentarios</label>
    <textarea
      name="comments"
      rows="4"
      class="form-control"
      placeholder="Comentarios del informe"
    ></textarea>
  </div>

  <button type="submit" class="btn btn-success">Guardar informe</button>
</form>

<script>
  (function () {
    function toNumber(value) {
      if (value === null || value === undefined || value === '') return null;
      const n = Number(value);
      return Number.isNaN(n) ? null : n;
    }

    function average(inputs) {
      const values = inputs
        .map((el) => toNumber(el.value))
        .filter((v) => v !== null);
      if (!values.length) return '';
      const sum = values.reduce((a, b) => a + b, 0);
      return (sum / values.length).toFixed(2);
    }

    function setupGroup(fieldNames, totalName) {
      const inputs = fieldNames
        .map((name) => document.querySelector(`input[name="${name}"]`))
        .filter(Boolean);
      const totalInput = document.querySelector(`input[name="${totalName}"]`);
      if (!inputs.length || !totalInput) return;

      function recalc() {
        totalInput.value = average(inputs);
      }

      inputs.forEach((input) => {
        input.addEventListener('input', recalc);
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      setupGroup(
        [
          'tech_cobertura_balon',
          'tech_conduccion',
          'tech_control',
          'tech_regate',
          'tech_disparo',
          'tech_pase',
          'tech_remate_cabeza',
          'tech_anticipacion',
        ],
        'tech_total',
      );
      setupGroup(
        [
          'tact_transicion_ataque_defensa',
          'tact_movimientos_sin_balon',
          'tact_ayudas_defensivas',
          'tact_ayudas_ofensivas',
          'tact_desmarques',
          'tact_marcajes',
        ],
        'tact_total',
      );
      setupGroup(
        [
          'phys_sacrificio',
          'phys_velocidad_punta',
          'phys_velocidad_reaccion',
          'phys_fuerza',
          'phys_potencia',
          'phys_resistencia',
          'phys_coordinacion',
        ],
        'phys_total',
      );
      setupGroup(
        [
          'psych_concentracion',
          'psych_control_emocional',
          'psych_reaccion_errores_arbitrales',
        ],
        'psych_total',
      );
      setupGroup(
        [
          'pers_liderazgo',
          'pers_disciplina',
          'pers_reaccion_correcciones_companero',
          'pers_reaccion_correcciones_tecnico',
        ],
        'pers_total',
      );
    });
  })();
</script>
