<%
function buildSortLink(field) {
  const params = [];
  if (filters && filters.team) params.push(`team=${encodeURIComponent(filters.team)}`);
  const nextDir = (sort === field && dir === 'asc') ? 'desc' : 'asc';
  params.push(`sort=${field}`);
  params.push(`dir=${nextDir}`);
  return `?${params.join('&')}`;
}
%>

<h1 class="mb-4">Informes guardados</h1>

<div class="mb-3 d-flex justify-content-between flex-wrap gap-2">
  <form class="d-flex align-items-end gap-2 flex-wrap" method="GET">
    <div>
      <label for="team" class="form-label mb-1">Equipo</label>
      <select name="team" id="team" class="form-select form-select-sm">
        <option value="">Todos</option>
        <% teams && teams.forEach(function(t){ %>
          <option value="<%= t %>" <%= filters.team === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
    </div>
    <input type="hidden" name="sort" value="<%= sort %>">
    <input type="hidden" name="dir" value="<%= dir %>">
    <button type="submit" class="btn btn-primary btn-sm">Filtrar</button>
    <a href="/reports" class="btn btn-link btn-sm">Limpiar</a>
  </form>
  <a href="/reports/export/csv" class="btn btn-outline-secondary btn-sm">
    Exportar CSV
  </a>
</div>

<% if (!reports || !reports.length) { %>
<p>No hay informes registrados.</p>
<% } else { %>
<form
  method="POST"
  action="/reports/bulk-delete"
  onsubmit="return confirm('¿Seguro que quieres borrar los informes seleccionados?');"
>
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>
          <input type="checkbox" id="selectAllReports" />
        </th>
        <th><a href="<%= buildSortLink('id') %>">ID</a></th>
        <th><a href="<%= buildSortLink('player') %>">Jugador</a></th>
        <th><a href="<%= buildSortLink('year') %>">Año</a></th>
        <th>Club</th>
        <th><a href="<%= buildSortLink('team') %>">Equipo</a></th>
        <th><a href="<%= buildSortLink('rating') %>">Valoración global</a></th>
        <th>Scout</th>
        <th><a href="<%= buildSortLink('created') %>">Fecha</a></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% reports.forEach((r) => { %>
      <tr>
        <td>
          <input
            type="checkbox"
            class="report-select"
            name="reportIds"
            value="<%= r.id %>"
          />
        </td>
        <td><%= r.id %></td>
        <td><%= r.player_name %> <%= r.player_surname %></td>
        <td><%= r.year || '' %></td>
        <td><%= r.club || '' %></td>
        <td><%= r.team || '' %></td>
        <td><%= r.overall_rating != null ? Number(r.overall_rating).toFixed(2) : '' %></td>
        <td><%= r.created_by_name || '' %></td>
        <td><%= r.created_at.toISOString().slice(0, 10) %></td>
        <td class="text-nowrap">
          <a class="btn btn-sm btn-primary me-1" href="/reports/<%= r.id %>">
            Ver
          </a>
          <a class="btn btn-sm btn-outline-secondary me-1" href="/reports/<%= r.id %>/edit">
            Editar
          </a>
          <form
            method="POST"
            action="/reports/<%= r.id %>/delete"
            style="display:inline"
            onsubmit="return confirm('¿Seguro que quieres borrar este informe?');"
          >
            <button type="submit" class="btn btn-sm btn-outline-danger">
              Borrar
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3">
  <button type="submit" class="btn btn-danger btn-sm">
    Borrar seleccionados
  </button>
</div>
</form>
<% } %>

<script>
  (function () {
    var selectAll = document.getElementById('selectAllReports');
    if (!selectAll) return;
    selectAll.addEventListener('change', function () {
      var checks = document.querySelectorAll('input.report-select');
      checks.forEach(function (c) {
        c.checked = selectAll.checked;
      });
    });
  })();
</script>

