<h1 class="mb-4">Informes guardados</h1>

<% if (!reports || !reports.length) { %>
<p>No hay informes registrados.</p>
<% } else { %>
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead>
      <tr>
        <th>ID</th>
        <th>Jugador</th>
        <th>Año</th>
        <th>Club</th>
        <th>Equipo</th>
        <th>Valoración global</th>
        <th>Scout</th>
        <th>Fecha</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% reports.forEach((r) => { %>
      <tr>
        <td><%= r.id %></td>
        <td><%= r.player_name %> <%= r.player_surname %></td>
        <td><%= r.year || '' %></td>
        <td><%= r.club || '' %></td>
        <td><%= r.team || '' %></td>
        <td><%= r.overall_rating != null ? Number(r.overall_rating).toFixed(2) : '' %></td>
        <td><%= r.created_by_name || '' %></td>
        <td><%= r.created_at.toISOString().slice(0, 10) %></td>
        <td class="text-nowrap">
          <a class="btn btn-sm btn-primary me-1" href="/reports/<%= r.id %>">
            Ver
          </a>
          <a class="btn btn-sm btn-outline-secondary me-1" href="/reports/<%= r.id %>/edit">
            Editar
          </a>
          <form
            method="POST"
            action="/reports/<%= r.id %>/delete"
            style="display:inline"
            onsubmit="return confirm('¿Seguro que quieres borrar este informe?');"
          >
            <button type="submit" class="btn btn-sm btn-outline-danger">
              Borrar
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
